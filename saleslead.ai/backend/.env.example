# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://saleslead:saleslead@localhost:5432/saleslead

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=...

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Get from: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=...
# Create a Conversational AI agent and paste its ID here
ELEVENLABS_AGENT_ID=...

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=...
# Twilio sandbox number (format: whatsapp:+14155238886)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── App ───────────────────────────────────────────────────────────────────────
RUPEEZY_SIGNUP_BASE_URL=https://rupeezy.in/ap?ref=
FRONTEND_URL=http://localhost:3000
